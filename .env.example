# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Optional token for the Telegram Assistant Bot integration.
# Obtain from Telegram's @BotFather and configure via the Secrets panel.
TELEGRAM_BOT_TOKEN=

# SUPABASE_URL: Required backend URL for cloud idea storage.
SUPABASE_URL=

# SUPABASE_ANON_KEY: Required anonymous key for the Supabase project.
SUPABASE_ANON_KEY=

